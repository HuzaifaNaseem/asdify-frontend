# Local dev: omit VITE_API_URL and use the Vite proxy. Proxy target must match Asdify-backend listen URL (see backend .env PORT).
# VITE_API_PROXY_TARGET=http://127.0.0.1:5000

# Vercel production: set VITE_API_URL to your deployed API (e.g. https://asdify-api.vercel.app, no trailing slash),
# OR enable Firestore discovery below so the SPA reads the ngrok URL the backend publishes on startup.
# VITE_API_URL=https://your-api.vercel.app

# --- Firestore API discovery (ngrok URL from backend) ---
# When VITE_FIREBASE_API_DISCOVERY=1, the app always uses the ngrok URL from Firestore for API calls
# (including on localhost — not the Vite dev proxy). Requires backend CORS to allow your frontend origin.
# Firebase Console → Project settings → Your apps → Web app → copy config values.
# Firestore rules must allow read on the server registry document (example):
#   match /asdify_servers/{docId} { allow read: if true; allow write: if false; }
# VITE_FIREBASE_API_DISCOVERY=1
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIRESTORE_SERVER_COLLECTION=asdify_servers
# VITE_FIRESTORE_SERVER_DOC_ID=local_backend
